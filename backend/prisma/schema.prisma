// FLOWIT MVP - Prisma Schema
// Database: PostgreSQL (Supabase)
// ORM: Prisma
// Framework: NestJS

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  USER
  MODERATOR   // 콘텐츠 관리자 (신고 처리)
  ADMIN       // DreamCoders 운영 관리자 (회원/크레딧/문의)
  SUPER_ADMIN // CEO (전체 권한)
}

enum UserPlan {
  FREE
  PRO
  PREMIUM
}

enum WorkspaceType {
  PROJECT
  STUDY
}

enum ProjectRole {
  ADMIN  // 관리자 (구 PM)
  MEMBER // 멤버
  MENTOR // 멘토 (준비중)
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum SprintStatus {
  PLANNED  // 예정
  ACTIVE   // 진행중
  COMPLETED // 완료
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW // 검토중
  HELP
  DONE
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
  URGENT // 긴급
}

enum TaskType {
  CODE      // 코드
  DOCUMENT  // 문서
  DESIGN    // 디자인
  PLANNING  // 기획
  RESEARCH  // 리서치
  OTHER     // 기타
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_STATUS_CHANGED
  COMMENT_ADDED
  HELP_REQUESTED
  AGORA_ANSWERED
  AGORA_ACCEPTED
  CREDIT_RECEIVED
  PROJECT_VERIFIED
  CONTENT_MODERATED
  COFFEE_CHAT_REQUESTED
  COFFEE_CHAT_ACCEPTED
  COFFEE_CHAT_DECLINED
}

enum CoffeeChatStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

enum AgoraStatus {
  OPEN   // 미채택
  CLOSED // 채택완료
}

enum RecruitType {
  PROJECT
  STUDY
}

enum ApplicationStatus {
  PENDING  // 검토중
  ACCEPTED // 수락
  REJECTED // 거절
}

enum CreditTransactionType {
  EARN   // 획득 (아고라 채택 등)
  SPEND  // 소비 (AI멘토링, 아고라 현상금)
  REFUND // 환불
}

enum BadgeType {
  NEWBIE               // 뉴비 (회원가입)
  COMMUNICATOR         // 소통장인 (게시글10+좋아요100+댓글50)
  BEST_ANSWERER        // 명답자 (아고라 채택 10개)
  CURIOUS              // 호기심천국 (아고라 질문 10개)
  TASK_HUNTER          // 태스크 헌터 (DONE 100개)
  CAPTAIN              // 캡틴 (ADMIN 3프로젝트, 각 3명+)
  TEAM_PLAYER          // 팀플레이어 (프로젝트 참여 5개)
  ATTENDANCE_30        // 개근상 (30일 연속 출석)
  PRO_SUBSCRIBER       // PRO 구독 중
  PREMIUM_SUBSCRIBER   // PREMIUM 구독 중
}

enum TilVisibility {
  PRIVATE    // 본인만
  WORKSPACE  // 워크스페이스 팀원만
  PUBLIC     // 전체 공개
}

enum AIMessageRole {
  USER
  ASSISTANT
}

enum DocumentCategory {
  PLANNING      // 기획서
  DESIGN        // 설계서
  PRESENTATION  // 발표자료
  OTHER         // 기타
}

enum InquiryType {
  BUG
  FEATURE
  BETA_FEEDBACK
  GENERAL
}

enum InquiryStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ReportTarget {
  POST
  COMMENT
  USER
}

enum ReportReason {
  SPAM
  ABUSE
  INAPPROPRIATE
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
  ACTION_TAKEN
}

enum QuestType {
  DAILY
  WEEKLY
}

enum AssignmentSubmissionStatus {
  SUBMITTED // 제출완료
  LATE      // 지각 제출
}

enum StudyResourceCategory {
  LINK    // 링크
  FILE    // 파일
  VIDEO   // 영상
  OTHER   // 기타
}

// ============================================
// Phase 1: 커뮤니티 기능
// ============================================

// 1. 사용자
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String?
  name         String
  nickname     String?  @unique
  role         UserRole @default(USER)
  plan         UserPlan @default(FREE)
  credit         Int       @default(0)
  creditResetAt  DateTime? // 마지막 월별 크레딧 리셋 일시
  xp             Int       @default(0)
  level        Int      @default(1)
  bio          String?
  techStack    String[]
  avatarUrl    String?
  githubUrl    String?
  portfolioUrl String?

  // OAuth 관련 필드
  provider   String? // 'google', 'github', null(일반 로그인)
  providerId String? // OAuth provider의 사용자 ID

  // 스트릭
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastActiveDate DateTime?

  // 이메일 수신 설정
  emailPreferences Json @default("{\"marketing\":true,\"commentReply\":true,\"projectActivity\":true,\"weeklySummary\":true}")

  // 대표 뱃지
  displayBadgeType BadgeType?

  // 온보딩
  onboardingCompleted Boolean @default(false)

  isBanned Boolean   @default(false)
  bannedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations - 커뮤니티
  posts         Post[]         @relation("UserPosts")
  postComments  PostComment[]
  postLikes     PostLike[]
  postBookmarks PostBookmark[]

  // Relations - PM툴
  createdProjects    Project[]       @relation("ProjectCreator")
  projectMemberships ProjectMember[]
  assignedTasks      Task[]          @relation("TaskAssignee")
  createdTasks       Task[]          @relation("TaskCreator")
  taskComments       TaskComment[]
  createdSprints     Sprint[]        @relation("SprintCreator")

  // Relations - 팀원모집
  recruits            Recruit[]
  recruitApplications RecruitApplication[]

  // Relations - 아고라
  agoraQuestions Agora[]
  agoraAnswers   AgoraAnswer[]

  // Relations - 크레딧/뱃지
  creditTransactions CreditTransaction[]
  userBadges         UserBadge[]

  // Relations - AI멘토링
  aiConversations AIConversation[]

  // Relations - 산출문서
  uploadedDocuments Document[]

  // Relations - 알림/인증
  notifications     Notification[] @relation("NotificationRecipient")
  sentNotifications Notification[] @relation("NotificationSender")
  refreshTokens     RefreshToken[]

  // Relations - M8 운영 관리
  inquiries Inquiry[]
  reports   Report[]

  // Relations - M10 게이미피케이션
  tils           Til[]
  questProgresses QuestProgress[]
  referralCode   ReferralCode?
  referralUsage  ReferralUsage?

  // Relations - 스터디룸
  studySubmissions      StudyAssignmentSubmission[]
  studyPenaltyConsents  StudyPenaltyConsent[]
  studyPenaltyHistories StudyPenaltyHistory[]
  uploadedStudyResources StudyResource[]

  // Relations - 커피챗
  sentCoffeeChats     CoffeeChat[] @relation("CoffeeChatRequester")
  receivedCoffeeChats CoffeeChat[] @relation("CoffeeChatReceiver")

  // Relations - KPT 회고
  kptRetrospectives KptRetrospective[]

  // Relations - AI 커리큘럼
  curriculumRecommendations CurriculumRecommendation[]

  // 포트폴리오 공개 설정
  portfolioPublic    Boolean @default(true)
  portfolioSections  Json?   // { stats: true, grass: true, projects: true, badges: true, recentTILs: true }

  @@unique([provider, providerId])
  @@index([email])
  @@map("users")
}

// 5. 게시판
model Board {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  isPublic    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  posts Post[]

  @@map("boards")
}

// 6. 게시글
model Post {
  id          String  @id @default(uuid())
  boardId     String
  authorId    String
  title       String
  content     String
  viewCount   Int     @default(0)
  isPublished Boolean @default(true)
  isHidden    Boolean @default(false)
  isPinned    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  board     Board          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  author    User           @relation("UserPosts", fields: [authorId], references: [id], onDelete: Cascade)
  comments  PostComment[]
  likes     PostLike[]
  bookmarks PostBookmark[]
  postTags  PostTag[]

  @@index([boardId])
  @@index([authorId])
  @@index([title])
  @@index([boardId, createdAt(sort: Desc)])
  @@map("posts")
}

// 7. 댓글
model PostComment {
  id       String  @id @default(uuid())
  postId   String
  authorId String
  content  String
  parentId String?
  isHidden Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  post    Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  PostComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies PostComment[] @relation("CommentReplies")

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@map("post_comments")
}

// 8. 좋아요
model PostLike {
  id     String @id @default(uuid())
  postId String
  userId String

  createdAt DateTime @default(now())

  // Relations
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("post_likes")
}

// 9. 북마크
model PostBookmark {
  id     String @id @default(uuid())
  postId String
  userId String

  createdAt DateTime @default(now())

  // Relations
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("post_bookmarks")
}

// 10. 태그
model Tag {
  id   String @id @default(uuid())
  name String @unique

  createdAt DateTime @default(now())

  // Relations
  postTags PostTag[]

  @@map("tags")
}

// 11. 게시글-태그 연결
model PostTag {
  id     String @id @default(uuid())
  postId String
  tagId  String

  // Relations
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId])
  @@index([postId])
  @@index([tagId])
  @@map("post_tags")
}

// ============================================
// PM툴: 워크스페이스 (프로젝트 / 스터디룸)
// ============================================

// 12. 워크스페이스 (구 Project)
model Project {
  id            String        @id @default(uuid())
  name          String
  description   String?
  overview      String?       @db.Text
  type          WorkspaceType @default(PROJECT)
  techStack     String[]
  coverImageUrl String?
  githubUrl     String?
  startDate     DateTime?
  endDate       DateTime?
  issuePrefix   String?       // 이슈 번호 접두어 (예: FLOW, PRJ)
  status        ProjectStatus @default(ACTIVE)
  isPublic      Boolean       @default(false)
  createdById   String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  createdBy        User              @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  members          ProjectMember[]
  tasks            Task[]
  sprints          Sprint[]
  recruits         Recruit[]
  documents        Document[]
  documentEmbeddings DocumentEmbedding[]
  tils             Til[]

  // Relations - 스터디룸
  studyWeeks       StudyWeek[]
  studyPenaltyRule StudyPenaltyRule?
  studyResources   StudyResource[]

  @@index([createdById])
  @@index([status])
  @@index([type])
  @@map("projects")
}

// 13. 워크스페이스 멤버
model ProjectMember {
  id        String      @id @default(uuid())
  projectId String
  userId    String
  role      ProjectRole

  joinedAt DateTime @default(now())

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

// Sprint
model Sprint {
  id          String       @id @default(uuid())
  projectId   String
  name        String
  goal        String?
  startDate   DateTime?
  endDate     DateTime?
  status      SprintStatus @default(PLANNED)
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation("SprintCreator", fields: [createdById], references: [id], onDelete: Restrict)
  tasks     Task[]

  // Relations - KPT 회고
  kptRetrospectives KptRetrospective[]
  kptSummary        KptSummary?

  @@index([projectId])
  @@index([status])
  @@index([createdById])
  @@map("sprints")
}

// 14. 작업(태스크)
model Task {
  id          String       @id @default(uuid())
  projectId   String
  sprintId    String?      // Sprint 연결 (optional)
  title       String
  description String?
  assigneeId  String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  taskType    TaskType?    // AI멘토링 유형 분류
  helpReason   String?
  dueDate      DateTime?
  tags         String[]  @default([])
  issueNumber  Int?      // 프로젝트 내 이슈 순번 (자동 생성)
  position     Int       @default(0) // 칸반 컬럼 내 순서
  createdById  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint          Sprint?          @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  assignee        User?            @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy       User             @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  labels          TaskLabel[]
  comments        TaskComment[]
  aiConversations AIConversation[]

  @@index([projectId])
  @@index([sprintId])
  @@index([assigneeId])
  @@index([status])
  @@index([createdById])
  @@map("tasks")
}

// 15. 태스크 라벨
model TaskLabel {
  id     String @id @default(uuid())
  taskId String
  label  String

  // Relations
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_labels")
}

// 16. 태스크 코멘트
model TaskComment {
  id       String @id @default(uuid())
  taskId   String
  authorId String
  content  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([authorId])
  @@map("task_comments")
}

// ============================================
// 스터디룸 (WorkspaceType = STUDY)
// ============================================

// 주차별 커리큘럼
model StudyWeek {
  id         String    @id @default(uuid())
  projectId  String
  weekNumber Int       // 1, 2, 3...
  title      String    // 예: "1주차: TypeScript 기초"
  goal       String?
  startDate  DateTime?
  endDate    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignments StudyAssignment[]

  @@unique([projectId, weekNumber])
  @@index([projectId])
  @@map("study_weeks")
}

// 주차별 과제
model StudyAssignment {
  id          String    @id @default(uuid())
  weekId      String
  title       String
  description String?   @db.Text
  dueDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  week        StudyWeek                   @relation(fields: [weekId], references: [id], onDelete: Cascade)
  submissions StudyAssignmentSubmission[]

  @@index([weekId])
  @@map("study_assignments")
}

// 멤버별 과제 제출
model StudyAssignmentSubmission {
  id           String                     @id @default(uuid())
  assignmentId String
  userId       String
  content      String?                    @db.Text // 텍스트 인증
  proofUrl     String?                             // 증거 링크/URL
  status       AssignmentSubmissionStatus @default(SUBMITTED)

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  assignment StudyAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, userId])
  @@index([assignmentId])
  @@index([userId])
  @@map("study_assignment_submissions")
}

// 벌금 규칙 (프로젝트당 1개)
model StudyPenaltyRule {
  id             String    @id @default(uuid())
  projectId      String    @unique
  isEnabled      Boolean   @default(false) // 전원 동의 후 활성화
  depositAmount  Int       @default(0)     // 1인당 예치금 (크레딧)
  penaltyPerMiss Int       @default(0)     // 1회 미제출당 벌금 (크레딧)
  periodStart    DateTime?
  periodEnd      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project   Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  consents  StudyPenaltyConsent[]
  histories StudyPenaltyHistory[]

  @@map("study_penalty_rules")
}

// 벌금 동의
model StudyPenaltyConsent {
  id            String   @id @default(uuid())
  penaltyRuleId String
  userId        String
  agreedAt      DateTime @default(now())

  // Relations
  penaltyRule StudyPenaltyRule @relation(fields: [penaltyRuleId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([penaltyRuleId, userId])
  @@index([penaltyRuleId])
  @@index([userId])
  @@map("study_penalty_consents")
}

// 벌금 이력
model StudyPenaltyHistory {
  id            String @id @default(uuid())
  penaltyRuleId String
  userId        String
  amount        Int    // 차감 크레딧 (양수)
  reason        String // 예: "1주차 과제 미제출"

  createdAt DateTime @default(now())

  // Relations
  penaltyRule StudyPenaltyRule @relation(fields: [penaltyRuleId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([penaltyRuleId])
  @@index([userId])
  @@map("study_penalty_histories")
}

// 자료 공유
model StudyResource {
  id           String                @id @default(uuid())
  projectId    String
  uploadedById String
  title        String
  url          String?               // 링크형 자료
  fileUrl      String?               // 파일형 자료 (R2 URL)
  r2Key        String?               // R2 object key (삭제 시)
  category     StudyResourceCategory @default(LINK)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([uploadedById])
  @@index([category])
  @@map("study_resources")
}

// ============================================
// 커뮤니티: 팀원모집
// ============================================

model Recruit {
  id          String      @id @default(uuid())
  projectId   String      // 연결된 워크스페이스 (필수)
  authorId    String
  title       String
  description String      @db.Text
  type        RecruitType
  positions   String[]    // 포지션 태그
  maxMembers  Int
  deadline    DateTime?
  isClosed    Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project      Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author       User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  applications RecruitApplication[]

  @@index([projectId])
  @@index([authorId])
  @@index([type])
  @@index([isClosed])
  @@index([deadline])
  @@map("recruits")
}

model RecruitApplication {
  id          String            @id @default(uuid())
  recruitId   String
  applicantId String
  message     String?
  status      ApplicationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  recruit   Recruit @relation(fields: [recruitId], references: [id], onDelete: Cascade)
  applicant User    @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([recruitId, applicantId])
  @@index([recruitId])
  @@index([applicantId])
  @@map("recruit_applications")
}

// ============================================
// 커뮤니티: 아고라 (크레딧 현상금 Q&A)
// ============================================

model Agora {
  id        String      @id @default(uuid())
  authorId  String
  title     String
  content   String      @db.Text
  bounty    Int         @default(1) // 크레딧 현상금
  status    AgoraStatus @default(OPEN)
  viewCount Int         @default(0)
  isHidden  Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  author  User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  answers AgoraAnswer[]

  @@index([authorId])
  @@index([status])
  @@index([bounty])
  @@index([createdAt(sort: Desc)])
  @@map("agoras")
}

model AgoraAnswer {
  id         String  @id @default(uuid())
  agoraId    String
  authorId   String
  content    String  @db.Text
  isAccepted Boolean @default(false)
  isHidden   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  agora  Agora @relation(fields: [agoraId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([agoraId])
  @@index([authorId])
  @@map("agora_answers")
}

// ============================================
// 크레딧 & 뱃지
// ============================================

model CreditTransaction {
  id          String                @id @default(uuid())
  userId      String
  amount      Int                   // 양수: 획득, 음수: 소비
  type        CreditTransactionType
  description String
  relatedId   String?               // 관련 엔티티 ID (아고라 ID 등)

  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("credit_transactions")
}

model UserBadge {
  id       String    @id @default(uuid())
  userId   String
  badge    BadgeType
  earnedAt DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badge])
  @@index([userId])
  @@map("user_badges")
}

// ============================================
// AI 멘토링
// ============================================

model AIConversation {
  id          String  @id @default(uuid())
  userId      String
  title       String?
  taskId      String? // Help 상태에서 연결된 Task ID
  contextType String? // 'TASK' (향후 'DOCUMENT' 등 확장)
  contextId   String? // 참조 대상의 UUID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  task     Task?       @relation(fields: [taskId], references: [id], onDelete: SetNull)
  messages AIMessage[]

  @@index([userId])
  @@map("ai_conversations")
}

model AIMessage {
  id             String        @id @default(uuid())
  conversationId String
  role           AIMessageRole
  content        String        @db.Text
  taskType       String?       // TaskType 문자열 (CODE, DOCUMENT 등)
  modelUsed      String?       // 사용된 AI 모델 (예: claude-haiku-4-5)
  creditsUsed    Int           @default(0)
  rating         Int?          // 1=좋아요, -1=싫어요, null=미평가 (DRE-211)

  createdAt DateTime @default(now())

  // Relations
  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt(sort: Desc)])
  @@map("ai_messages")
}

// ============================================
// 알림
// ============================================

model Notification {
  id          String           @id @default(uuid())
  recipientId String
  senderId    String?
  type        NotificationType
  title       String
  message     String
  isRead      Boolean          @default(false)
  relatedId   String?

  createdAt DateTime @default(now())

  // Relations
  recipient User  @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  sender    User? @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([recipientId])
  @@index([senderId])
  @@index([isRead])
  @@index([recipientId, createdAt(sort: Desc)])
  @@map("notifications")
}

// ============================================
// 인증: Refresh Token
// ============================================

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)

  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================
// 산출문서 보관함
// ============================================

model Document {
  id           String           @id @default(uuid())
  projectId    String
  fileName     String
  fileUrl      String           // R2 Public URL
  r2Key        String           // R2 object key (삭제 시 사용)
  fileSize     Int              // bytes
  fileType     String           // MIME type
  category     DocumentCategory @default(OTHER)
  uploadedById String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  embeddings DocumentEmbedding[]

  @@index([projectId])
  @@index([uploadedById])
  @@index([category])
  @@map("documents")
}

// ============================================
// M8: 운영 관리 시스템
// ============================================

model Inquiry {
  id        String        @id @default(uuid())
  userId    String
  type      InquiryType
  title     String
  content   String        @db.Text
  status    InquiryStatus @default(OPEN)
  reply     String?       @db.Text
  repliedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("inquiries")
}

model Report {
  id         String       @id @default(uuid())
  reporterId String
  targetType ReportTarget
  targetId   String
  reason     ReportReason
  detail     String?      @db.Text
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  reporter User @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([status])
  @@index([targetType, targetId])
  @@map("reports")
}

// ============================================
// M10: 리텐션 & 게이미피케이션
// ============================================

// TIL (Today I Learned)
model Til {
  id          String        @id @default(uuid())
  authorId    String
  workspaceId String?       // 스터디 워크스페이스 ID (nullable - 기존 데이터 호환)
  title       String
  content     String        @db.Text
  date        DateTime      @db.Date  // 작성 날짜 (하루 1개 제한)
  tags        String[]      @default([])
  xpGranted   Boolean       @default(false)
  visibility  TilVisibility @default(PUBLIC)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  workspace Project? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([authorId, date])
  @@index([authorId])
  @@index([date])
  @@index([workspaceId])
  @@map("tils")
}

// 퀘스트 정의 (관리자가 시드로 생성)
model Quest {
  id           String    @id @default(uuid())
  title        String
  description  String
  type         QuestType @default(DAILY)
  conditionKey String    // 조건 키: 'TIL_WRITE', 'AGORA_ANSWER', 'AI_CHAT', 'COMMENT_WRITE', 'POST_WRITE'
  xpReward     Int       @default(0)
  creditReward Int       @default(0)
  isActive     Boolean   @default(true)

  createdAt DateTime @default(now())

  // Relations
  progresses QuestProgress[]

  @@index([type])
  @@index([isActive])
  @@map("quests")
}

// 사용자별 퀘스트 진행 상황
model QuestProgress {
  id          String    @id @default(uuid())
  userId      String
  questId     String
  date        DateTime  @db.Date  // 해당 날짜 (DAILY: 오늘, WEEKLY: 주 시작일)
  completed   Boolean   @default(false)
  completedAt DateTime?

  createdAt DateTime @default(now())

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest Quest @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([userId, questId, date])
  @@index([userId])
  @@index([questId])
  @@index([date])
  @@map("quest_progresses")
}

// 친구 초대 코드
model ReferralCode {
  id        String @id @default(uuid())
  code      String @unique
  userId    String @unique
  usedCount Int    @default(0)

  createdAt DateTime @default(now())

  // Relations
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages ReferralUsage[]

  @@map("referral_codes")
}

// 친구 초대 사용 기록
model ReferralUsage {
  id             String @id @default(uuid())
  referralCodeId String
  newUserId      String @unique  // 초대받아 가입한 사람 (1회만 사용 가능)

  createdAt DateTime @default(now())

  // Relations
  referralCode ReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)
  newUser      User         @relation(fields: [newUserId], references: [id], onDelete: Cascade)

  @@index([referralCodeId])
  @@map("referral_usages")
}

// ============================================
// 커피챗
// ============================================

model CoffeeChat {
  id          String           @id @default(uuid())
  requesterId String
  receiverId  String
  message     String
  status      CoffeeChatStatus @default(PENDING)
  meetingUrl  String?
  creditCost  Int              @default(10)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  requester User @relation("CoffeeChatRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User @relation("CoffeeChatReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([requesterId])
  @@index([receiverId])
  @@index([status])
  @@map("coffee_chats")
}

// ============================================
// KPT 회고
// ============================================

model KptRetrospective {
  id       String   @id @default(uuid())
  sprintId String
  userId   String
  keeps    String[]
  problems String[]
  tries    String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sprint Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sprintId, userId])
  @@index([sprintId])
  @@map("kpt_retrospectives")
}

model KptSummary {
  id       String @id @default(uuid())
  sprintId String @unique
  summary  String

  createdAt DateTime @default(now())

  // Relations
  sprint Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  @@map("kpt_summaries")
}

// ============================================
// RAG 임베딩 (DRE-178)
// ============================================

model DocumentEmbedding {
  id         String @id @default(uuid())
  documentId String
  projectId  String
  chunkIndex Int    @default(0)
  content    String @db.Text
  // embedding vector(1536)는 Prisma 미지원 → Raw SQL로만 접근
  metadata   Json   @default("{}")

  createdAt DateTime @default(now())

  // Relations
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([projectId])
  @@map("document_embeddings")
}

// ============================================
// AI 커리큘럼 추천 (DRE-179)
// ============================================

model CurriculumRecommendation {
  id          String   @id @default(uuid())
  userId      String
  items       Json     @default("[]")
  generatedAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, generatedAt(sort: Desc)])
  @@map("curriculum_recommendations")
}
